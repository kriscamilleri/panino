{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: Docker Compose Up",
      "type": "shell",
      "command": "docker compose -f docker-compose.dev.yml up --build",
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "docker"
      }
    },
    {
      "label": "Dev: Docker Compose Up (detached)",
      "type": "shell",
      "command": "docker compose -f docker-compose.dev.yml up --build -d && echo 'Containers started'",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "group": "docker"
      }
    },
    {
      "label": "Dev: Docker Compose Down",
      "type": "shell",
      "command": "docker compose -f docker-compose.dev.yml down",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "docker"
      }
    },
    {
      "label": "Dev: Frontend Only (npm)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "docker"
      }
    },
    {
      "label": "Prod: Docker Compose Up",
      "type": "shell",
      "command": "docker compose up -d",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "docker"
      }
    },
    {
      "label": "Prod: Docker Compose Down",
      "type": "shell",
      "command": "docker compose down",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "docker"
      }
    }
  ]
}
